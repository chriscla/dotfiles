#!/usr/bin/env bash
# Extension list fingerprint (bump comment when you add IDs): python-cursor-2
set -euo pipefail

{{ if or (eq .chezmoi.os "darwin") (eq .chezmoi.os "linux") -}}
{{ if .chezmoi.kernel -}}
{{   if contains "microsoft" (lower .chezmoi.kernel.osrelease) -}}
# WSL2: editors live on the Windows host; use the PowerShell script instead.
exit 0
{{   end -}}
{{ end -}}

# Cursor: Anysphere marketplace IDs where applicable.
EXTENSIONS_CURSOR=(
  "jdinhlife.gruvbox"
  "ms-python.python"
  "ms-python.vscode-python-envs"
  "anysphere.cursorpyright"
  "ms-python.debugpy"
  "anysphere.remote-containers"
  "charliermarsh.ruff"
)

# VS Code / VSCodium: Microsoft Remote-* and Pylance; no anysphere.* extensions.
EXTENSIONS_CODE=(
  "jdinhlife.gruvbox"
  "ms-python.python"
  "ms-python.vscode-python-envs"
  "ms-python.vscode-pylance"
  "ms-python.debugpy"
  "ms-vscode-remote.remote-containers"
  "charliermarsh.ruff"
)

# Resolve CLIs: try app-bundle paths before `command -v`.
# On macOS, Cursor’s palette “Install 'cursor' command in PATH” uses AppleScript (osascript) to add a shim;
# a `cursor` on PATH can also be a wrong/stub binary (e.g. under ~/.local/bin), so prefer
# …/Cursor.app/Contents/Resources/app/bin/cursor when present.
resolve_bin() {
  local name=$1
  shift
  local p
  for p in "$@"; do
    if [[ -x "$p" ]]; then
      printf '%s\n' "$p"
      return 0
    fi
  done
  if command -v "$name" &>/dev/null; then
    command -v "$name"
    return 0
  fi
  return 1
}

install_for_named() {
  local cmd=$1
  shift
  local -a exts=()
  case "$cmd" in
    cursor) exts=("${EXTENSIONS_CURSOR[@]}"); ;;
    code) exts=("${EXTENSIONS_CODE[@]}"); ;;
    *) return 0 ;;
  esac
  local bin
  if ! bin=$(resolve_bin "$cmd" "$@"); then
    return 0
  fi
  local ext
  for ext in "${exts[@]}"; do
    echo "📦 $bin --install-extension $ext --profile Default"
    "$bin" --install-extension "$ext" --profile "Default" </dev/null || true
  done
}

{{ if eq .chezmoi.os "darwin" -}}
install_for_named cursor \
  "/Applications/Cursor.app/Contents/Resources/app/bin/cursor" \
  "$HOME/Applications/Cursor.app/Contents/Resources/app/bin/cursor"
install_for_named code \
  "/Applications/Visual Studio Code.app/Contents/Resources/app/bin/code" \
  "/Applications/VSCodium.app/Contents/Resources/app/bin/codium" \
  "$HOME/Applications/Visual Studio Code.app/Contents/Resources/app/bin/code"
{{ else -}}
install_for_named cursor \
  "/usr/local/bin/cursor" \
  "/usr/bin/cursor" \
  "$HOME/.local/bin/cursor"
install_for_named code \
  "/usr/local/bin/code" \
  "/usr/bin/code" \
  "$HOME/.local/bin/code" \
  "/usr/bin/codium" \
  "$HOME/.local/bin/codium"
{{ end -}}

{{ else -}}
# Windows: use run_onchange_install-vscode-extensions.ps1
exit 0
{{ end -}}
