{{ if not .trusted }}
# Not a trusted machine: skip private keys and encrypted files.
# .ssh/rc, .ssh/config, and .ssh/*.pub contain no secrets so they still deploy.
.ssh/id_ed25519
.ssh/id_holiest
.ssh/ansible_rsa
**/*.age
{{ end }}

