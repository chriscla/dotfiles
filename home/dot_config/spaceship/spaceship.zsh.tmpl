# Display time
# SPACESHIP_TIME_SHOW=true
#
# # Display username always
SPACESHIP_USER_SHOW=always

SPACESHIP_VENV_PREFIX=venv:
#
# # Do not truncate path in repos
# SPACESHIP_DIR_TRUNC_REPO=false
#
# # Add custom Ember section
# # See: https://github.com/spaceship-prompt/spaceship-ember
# spaceship add ember
#
# # Add a custom vi-mode section to the prompt
# # See: https://spaceship-prompt/spaceship-vi-mode
# spaceship add --before char vi_mode

{{- if .work }}
# AWS (https://spaceship-prompt.sh/sections/aws/) — profile from AWS_VAULT or AWS_PROFILE
SPACESHIP_AWS_PREFIX='on '
SPACESHIP_AWS_SYMBOL='🅰 '
SPACESHIP_AWS_COLOR=blue
{{- end }}
