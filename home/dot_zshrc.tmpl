if [ -n "${ZSH_DEBUGRC+1}" ]; then
    zmodload zsh/zprof
fi

export COLORTERM="truecolor"

# XDG-compliant history/config locations
export PSQL_HISTORY="$XDG_STATE_HOME/psql/history"
export DOCKER_CONFIG="$XDG_CONFIG_HOME/docker"
export LESSHISTFILE="$XDG_STATE_HOME/less/history"

{{- if .work }}
# AWS: keep config and credentials under XDG
export AWS_CONFIG_FILE="$XDG_CONFIG_HOME/aws/config"
export AWS_SHARED_CREDENTIALS_FILE="$XDG_CONFIG_HOME/aws/credentials"
export AWS_CLI_HISTORY_FILE="$XDG_DATA_HOME/aws/history"
{{- end }}

# --- Oh My Zsh configuration (must be set before sourcing) ---

ZSH_THEME=""
zstyle ':omz:update' mode disabled

plugins=(
  z
  chezmoi
{{- if .work }}
  zsh-aws-vault
{{- end }}
  colorize
  uv
  git
  tmux
  ssh-agent
  fzf-tab
  zsh-autosuggestions
  zsh-syntax-highlighting
)

zstyle ':omz:plugins:ssh-agent' lazy yes
zstyle ':omz:plugins:ssh-agent' agent-forwarding yes
zstyle ':autocomplete:*' insert-unambiguous yes

# Auto-start tmux on SSH sessions
if [[ -n "$SSH_CONNECTION" ]]; then
  ZSH_TMUX_AUTOSTART=true
else
  ZSH_TMUX_AUTOSTART=false
fi
{{- if eq .chezmoi.os "darwin" }}
ZSH_TMUX_ITERM2=true
{{- end }}

# VirtualEnvWrapper
export WORKON_HOME=$HOME/.venvs
export VIRTUALENVWRAPPER_PYTHON=$WORKON_HOME/venvwrapper_venv/bin/python3
export VIRTUALENVWRAPPER_VIRTUALENV=$WORKON_HOME/venvwrapper_venv/bin/virtualenv
export PROJECT_HOME=$HOME/code

# Performance tweaks
ZSH_DISABLE_MAGIC_FUNCTIONS=true
ZSH_DISABLE_COMPFIX=true

# zsh-autosuggestions: suppress gray history hints for `z` / `z ...`
# Must be defined before the plugin loads; async mode is left off because it
# can break custom strategies.
_zsh_autosuggest_strategy_skip_z_jump() {
  emulate -L zsh
  if [[ "$1" == z ]] || [[ "$1" == z[[:space:]]* ]]; then
    typeset -g suggestion="$1"
  else
    typeset -g suggestion=""
  fi
}
typeset -ga ZSH_AUTOSUGGEST_STRATEGY
ZSH_AUTOSUGGEST_STRATEGY=(skip_z_jump history)

source $ZSH/oh-my-zsh.sh

# Source fzf keybindings/completions (cached for speed)
if (( $+commands[fzf] )); then
  _fzf_cache="$XDG_CACHE_HOME/fzf/fzf.zsh"
  if [[ ! -f "$_fzf_cache" || "$_fzf_cache" -ot =fzf ]]; then
    mkdir -p "${_fzf_cache:h}"
    fzf --zsh > "$_fzf_cache"
  fi
  source "$_fzf_cache"
  unset _fzf_cache
fi

export LANG=en_US.UTF-8
export MANPAGER="nvim +Man!"

path+=("$HOME/bin")
path+=("$HOME/.local/bin")
path+=("/usr/local/go/bin")
path+=("$HOME/.dotnet/tools")
path+=("/usr/local/opt/libpq/bin")
export PATH

# Aliases
alias dcp="docker compose -f /opt/docker/docker-compose.yml"
alias dce='() { dcp exec -it $1 /bin/bash ;}'
alias dcr='dcp run --rm'
alias dcpe='${EDITOR:-vim} /opt/docker/docker-compose.yml'
alias appdata="cd /opt/appdata"
alias chownmedia='() { sudo chown -R media:media $1;sudo chmod -R g+rws,o+r $1 ;}'
# SSH wrapper: tint tmux pane background to indicate remote session
ssh() {
  if [[ -n "$TMUX" ]]; then
    tmux select-pane -P 'bg=#1d2021'
    command ssh "$@"
    tmux select-pane -P 'bg=default'
  else
    command ssh "$@"
  fi
}

alias smurf='ssh cyrus@murf'
alias vim="nvim"
alias vi="nvim"
alias nvim-update='nvim --headless "+Lazy! sync" +qa && chezmoi add ~/.config/nvim/lazy-lock.json'
alias zsh_zprof='time ZSH_DEBUGRC=1 zsh -i -c exit'

envrun() {
  if [ -f .env ]; then
    # The parentheses ( ) create a subshell
    (
      # Export variables, ignoring comments and empty lines
      export $(grep -v '^#' .env | xargs)
      # Execute the command within this protected environment
      exec "$@"
    )
  else
    echo "Error: .env file not found."
    return 1
  fi
}

unalias z 2> /dev/null
# OMZ "z" plugin is zsh-z: the command is `zshz` (see $ZSH/plugins/z/z.plugin.zsh). `_z` is only a
# completion helper, not the directory list — use `zshz` here so fzf gets the real stack listing.
z() {
  local dir=$(
    zshz 2>&1 |
    fzf --height 40% --layout reverse --info inline \
        --nth 2.. --tac --no-sort --query "$*" \
        --accept-nth 2..
  ) && cd "$dir"
}

# `z` is an interactive fzf picker (Enter runs it). Disable fzf-tab for it so Tab uses normal
# zsh completion instead of a misleading fzf menu.
zstyle ':fzf-tab:complete:z:*' disabled-on any

# SSH completion: only use ~/.ssh/config hosts, not known_hosts
zstyle ':completion:*:(ssh|scp|rsync):*' known-hosts-files /dev/null

# fzf-tab: if only one match, accept it immediately (no pointless one-row fzf UI).
zstyle ':fzf-tab:*' fzf-flags --select-1
# Quieter group headers — avoids extra leading text in the fzf UI in some themes/list-colors setups.
# Use `show-group full` if you want colored group labels back.
zstyle ':fzf-tab:*' show-group quiet

if (( $+commands[starship] )); then
  _starship_cache="$XDG_CACHE_HOME/starship/init.zsh"
  if [[ ! -f "$_starship_cache" || "$_starship_cache" -ot =starship ]]; then
    mkdir -p "${_starship_cache:h}"
    starship init zsh > "$_starship_cache"
  fi
  source "$_starship_cache"
  unset _starship_cache
fi

if [ -n "${ZSH_DEBUGRC+1}" ]; then
    zprof
fi
