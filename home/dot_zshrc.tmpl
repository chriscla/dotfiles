if [ -n "${ZSH_DEBUGRC+1}" ]; then
    zmodload zsh/zprof
fi
# If you come from bash you might have to change your $PATH.
# export PATH=$HOME/bin:/usr/local/bin:$PATH
export XDG_DATA_HOME=$HOME/.local/share
export XDG_CONFIG_HOME=$HOME/.config
export XDG_STATE_HOME=$HOME/.local/state
export XDG_CACHE_HOME=$HOME/.cache

# TODO: Set this better based on what type of session we're in
export COLORTERM="truecolor"

# Path to your oh-my-zsh installation.
export ZSH="$HOME/.oh-my-zsh"

# PostgreSQL
export PSQL_HISTORY="$XDG_STATE_HOME/psql/history"

# Docker
export DOCKER_CONFIG="$XDG_CONFIG_HOME/docker"

{{- if .work }}
# AWS: keep config and credentials under XDG (~/.config/aws managed by chezmoi on work machines)
export AWS_CONFIG_FILE="$XDG_CONFIG_HOME/aws/config"
export AWS_SHARED_CREDENTIALS_FILE="$XDG_CONFIG_HOME/aws/credentials"
export AWS_CLI_HISTORY_FILE="$XDG_DATA_HOME/aws/history"
{{- end }}

export LESSHISTFILE="$XDG_STATE_HOME/less/history"

ZSH_THEME=""

# Uncomment the following line to use case-sensitive completion.
# CASE_SENSITIVE="true"

# Uncomment the following line to use hyphen-insensitive completion.
# Case-sensitive completion must be off. _ and - will be interchangeable.
# HYPHEN_INSENSITIVE="true"

zstyle ':omz:update' mode disabled  # disable automatic updates

# Would you like to use another custom folder than $ZSH/custom?
# ZSH_CUSTOM=/path/to/new-custom-folder
#

# ZSH Autosuggestion speedup
ZSH_AUTOSUGGEST_USE_ASYNC=1

# Which plugins would you like to load?
# Standard plugins can be found in $ZSH/plugins/
# Custom plugins may be added to $ZSH_CUSTOM/plugins/
# Example format: plugins=(rails git textmate ruby lighthouse)
# Add wisely, as too many plugins slow down shell startup.
plugins=(
  z
  chezmoi
{{ if .work }}
  zsh-aws-vault
{{ end }}
  colorize
  uv
  git
  tmux
  ssh-agent
  fzf-tab
  zsh-autosuggestions
  zsh-syntax-highlighting
)

# Loads keys only on first-use
zstyle ':omz:plugins:ssh-agent' lazy yes

# Enable agent-forwarding
zstyle ':omz:plugins:ssh-agent' agent-forwarding yes

# Tab to the most common completion
zstyle ':autocomplete:*' insert-unambiguous yes

# TMUX Config
ZSH_TMUX_AUTOSTART=false
ZSH_TMUX_ITERM2=true # Sets -CC option for iterm2 tmux integration

#VirtualEnvWrapper
export WORKON_HOME=$HOME/.venvs
export VIRTUALENVWRAPPER_PYTHON=$WORKON_HOME/venvwrapper_venv/bin/python3
export VIRTUALENVWRAPPER_VIRTUALENV=$WORKON_HOME/venvwrapper_venv/bin/virtualenv
export PROJECT_HOME=$HOME/code

# Disable Auto-update with chezmoi
DISABLE_AUTO_UPDATE="true"

# Speedup loading
ZSH_DISABLE_MAGIC_FUNCTIONS=true
ZSH_DISABLE_COMPFIX=true

# zsh-autosuggestions: suppress gray history hints for `z` / `z …` (must be set before the plugin loads).
_zsh_autosuggest_strategy_skip_z_jump() {
  emulate -L zsh
  if [[ "$1" == z ]] || [[ "$1" == z[[:space:]]* ]]; then
    typeset -g suggestion="$1"
  else
    typeset -g suggestion=""
  fi
}
typeset -ga ZSH_AUTOSUGGEST_STRATEGY
ZSH_AUTOSUGGEST_STRATEGY=(skip_z_jump history)

source $ZSH/oh-my-zsh.sh

# Sourcing fzf directly may be faster. 
# ~/.oh-my-zsh/custom/fzf-setup.zsh
_fzf_cache="$XDG_CACHE_HOME/fzf/fzf.zsh"
if [[ ! -f "$_fzf_cache" || "$_fzf_cache" -ot =fzf ]]; then
  mkdir -p "${_fzf_cache:h}"
  fzf --zsh > "$_fzf_cache"
fi
source "$_fzf_cache"
unset _fzf_cache

# Async mode can break custom autosuggest strategies in some setups; keep suggestions synchronous.
unset ZSH_AUTOSUGGEST_USE_ASYNC

# User configuration

# export MANPATH="/usr/local/man:$MANPATH"

# You may need to manually set your language environment
export LANG=en_US.UTF-8

#Preferred editor for local and remote sessions
#if [[ -n $SSH_CONNECTION ]]; then
export VISUAL='nvim'
export EDITOR="$VISUAL"
export MANPAGER="nvim +Man!"
# else
#   export EDITOR='mvim'
# fi

# Compilation flags
# export ARCHFLAGS="-arch x86_64"
#
path+=("$HOME/bin")
path+=("$HOME/.local/bin")
path+=("/usr/local/go/bin")
path+=("$HOME/.dotnet/tools")
path+=("/usr/local/opt/libpq/bin")
export PATH

# Set personal aliases, overriding those provided by oh-my-zsh libs,
# plugins, and themes. Aliases can be placed here, though oh-my-zsh
# users are encouraged to define aliases within the ZSH_CUSTOM folder.
# For a full list of active aliases, run `alias`.
#
# Example aliases
# alias zshconfig="mate ~/.zshrc"
alias dcp="docker compose -f ~/docker-compose.yml"
alias dce='() { dcp exec -it $1 /bin/bash ;}'
alias dcr='dcp run --rm'
alias appdata="cd /opt/appdata"
alias chownmedia='() { sudo chown -R media:media $1;sudo chmod -R g+rws,o+r $1 ;}'
alias smurf='ssh ansible@murf.at2311.com'
alias vim="nvim"
alias vi="nvim"
alias nvim-update='nvim --headless "+Lazy! sync" +qa && chezmoi add ~/.config/nvim/lazy-lock.json'
alias zsh_zprof='time ZSH_DEBUGRC=1 zsh -i -c exit'

envrun() {
  if [ -f .env ]; then
    # The parentheses ( ) create a subshell
    (
      # Export variables, ignoring comments and empty lines
      export $(grep -v '^#' .env | xargs)
      # Execute the command within this protected environment
      exec "$@"
    )
  else
    echo "Error: .env file not found."
    return 1
  fi
}

unalias z 2> /dev/null
# OMZ "z" plugin is zsh-z: the command is `zshz` (see $ZSH/plugins/z/z.plugin.zsh). `_z` is only a
# completion helper, not the directory list — use `zshz` here so fzf gets the real stack listing.
z() {
  local dir=$(
    zshz 2>&1 |
    fzf --height 40% --layout reverse --info inline \
        --nth 2.. --tac --no-sort --query "$*" \
        --accept-nth 2..
  ) && cd "$dir"
}

# `z` is an interactive fzf picker (Enter runs it). Disable fzf-tab for it so Tab uses normal
# zsh completion instead of a misleading fzf menu.
zstyle ':fzf-tab:complete:z:*' disabled-on any

# fzf-tab: if only one match, accept it immediately (no pointless one-row fzf UI).
zstyle ':fzf-tab:*' fzf-flags --select-1
# Quieter group headers — avoids extra leading text in the fzf UI in some themes/list-colors setups.
# Use `show-group full` if you want colored group labels back.
zstyle ':fzf-tab:*' show-group quiet

_starship_cache="$XDG_CACHE_HOME/starship/init.zsh"
if [[ ! -f "$_starship_cache" || "$_starship_cache" -ot =starship ]]; then
  mkdir -p "${_starship_cache:h}"
  starship init zsh > "$_starship_cache"
fi
source "$_starship_cache"
unset _starship_cache

if [ -n "${ZSH_DEBUGRC+1}" ]; then
    zprof
fi
